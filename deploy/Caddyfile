# Caddyfile — reverse proxy + automatic HTTPS for The Dunk Contest.
# Install to /etc/caddy/Caddyfile, then: sudo systemctl reload caddy
#
# Replace example.com with your real domain (apex). Caddy fetches and
# auto-renews the Let's Encrypt cert on its own — no certbot, no cron.
# reverse_proxy upgrades WebSocket (socket.io) connections automatically.

example.com {
	encode zstd gzip
	reverse_proxy 127.0.0.1:3000
}

# Send www to the apex so there's one canonical URL.
www.example.com {
	redir https://example.com{uri} permanent
}
